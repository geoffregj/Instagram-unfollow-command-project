#  MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    print("╔══════════════════════════════════════════╗")
    print("║   Instagram Analyzer — hunter15.py       ║")
    print("║   Bulk ID fetch · No per-user lookups    ║")
    print("╚══════════════════════════════════════════╝")
    print("""
  [1] Parse export files only
  [2] Auto-unfollow (uses saved session)
  [3] Parse + auto-unfollow in one go
  [4] Clear saved session
""")
    choice = input("  Choice [1-4]: ").strip()

    if choice == "4":
        for f in [SESSION_FILE, ID_CACHE_FILE]:
            if os.path.exists(f):
                os.remove(f)
                print(f"   ✔  Deleted {f}")
        return

    if choice in ("1", "3"):
        following, followers = load_export_data()
        res     = analyse(following, followers)
        print_report(following, followers, res)
        targets = res["not_following_back"]
    elif choice == "2":
        if not os.path.exists(RESULTS_FILE):
            sys.exit(f"❌  Run option 1 first.")
        with open(RESULTS_FILE) as f:
            targets = json.load(f)["not_following_back"]
        print(f"\n📂  Loaded {len(targets)} targets from {RESULTS_FILE}")
    else:
        print("Invalid choice.")
        return

    if choice == "1":
        return

    if not REQUESTS_AVAILABLE:
        sys.exit("❌  Run: pip install requests")

    if not targets:
        print("\n🎉  No one to unfollow!")
        return

    # Login / restore session
    session  = None
    saved    = load_session()

    if saved:
        print(f"\n✔  Found saved session for @{saved.get('username','?')}")
        reuse = input("   Use saved session? [Y/n]: ").strip().lower()
        if reuse != "n":
            session = restore_session(saved)
            print("   🔍  Verifying session...", end=" ", flush=True)
            if verify_session(session):
                print("✔  Valid!")
            else:
                print("✘  Expired.")
                session = None

    if session is None:
        username = input("\n   Instagram username: ").strip()
        password = input("   Instagram password: ").strip()
        session  = login_web(username, password)
        if session is None:
            sys.exit("❌  Login failed.")
        saved = load_session()

    user_id = saved.get("user_id") if saved else None
    if not user_id:
        sys.exit("❌  Could not get user ID from session.")

    print(f"\n   {len(targets)} accounts to unfollow.")
    raw = input("   How many this session? (default 20, safe max ~30): ").strip()
    try:
        batch = max(1, min(int(raw), 200)) if raw else 20
    except ValueError:
        batch = 20

    confirm = input(f"\n⚠  Unfollow {batch} accounts? [y/N]: ").strip().lower()
    if confirm != "y":
        print("   Cancelled.")
        return

    run_unfollow(targets, session, user_id, max_batch=batch)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n⛔  Interrupted.")
